rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidQuizSession(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'quizData']) &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /quiz_sessions/{sessionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(sessionId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(sessionId) && isValidQuizSession(incoming());
      allow update: if false; // Sessions are immutable once saved
      allow delete: if isSignedIn() && isValidId(sessionId) && existing().userId == request.auth.uid;
    }
  }
}
